      <hashTree>
        <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="BeanShell 取样器">
          <stringProp name="BeanShellSampler.query">// 初始化：读取CSV文件，创建Token Map
import org.apache.commons.io.FileUtils;
import java.io.File;
import java.util.List;
import java.util.HashMap;

log.info(&quot;===== 开始初始化Token池 =====&quot;);

try {
    // 1. 读取CSV文件
    File csvFile = new File(vars.get(&quot;filePath&quot;));
    List lines = FileUtils.readLines(csvFile, &quot;UTF-8&quot;);
    
    // 2. 创建Map，key是线程号，value是[token, refreshToken]
    HashMap map = new HashMap();
    
    // 3. 循环处理每一行（从第2行开始，跳过表头）
    for (int i = 1; i &lt; lines.size(); i++) {
        String line = (String) lines.get(i);
        String[] parts = line.split(&quot;,&quot;);
        
        // 创建token数组
        String[] tokenPair = new String[2];
        tokenPair[0] = parts[0];  // token
        tokenPair[1] = parts[1];  // refreshToken
        
        // 线程号从0开始
        Integer threadId = new Integer(i - 1);
        map.put(threadId, tokenPair);
        
        // 打印前3个token看看
        if (i &lt;= 3) {
            log.info(&quot;线程&quot; + threadId + &quot; 初始化Token: &quot; + parts[0].substring(0, 20) + &quot;...&quot;);
        }
    }
    
    // 4. 保存到JMeter属性
    props.put(&quot;tokenMap&quot;, map);
    log.info(&quot;初始化完成，共 &quot; + map.size() + &quot; 个token&quot;);
    
} catch (Exception e) {
    log.error(&quot;初始化失败: &quot; + e.toString());
}</stringProp>
        </BeanShellSampler>
