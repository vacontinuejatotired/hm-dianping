          <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell 预处理程序">
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <boolProp name="resetInterpreter">false</boolProp>
            <stringProp name="script">// 预处理脚本 - 获取token并设置到请求头
import org.apache.jmeter.protocol.http.control.Header;
import org.apache.jmeter.protocol.http.control.HeaderManager;

int threadNum = ctx.getThreadNum();
HashMap map = (HashMap) props.get(&quot;tokenMap&quot;);

if (map != null) {
    Integer key = new Integer(threadNum);
    String[] tokenPair = (String[]) map.get(key);
    
    if (tokenPair != null) {
        String token = tokenPair[0];
        String refreshToken = tokenPair[1];
        
        // 1. 设置到变量（供后续使用）
        vars.put(&quot;token&quot;, token);
        vars.put(&quot;refreshToken&quot;, refreshToken);
        
        // 2. 创建HeaderManager并添加两个Header
        HeaderManager headerManager = new HeaderManager();
        headerManager.add(new Header(&quot;Authorization&quot;, token));
        headerManager.add(new Header(&quot;Refresh-Token&quot;, refreshToken));  // 添加Refresh Token
        
        // 3. 设置到请求
        sampler.setHeaderManager(headerManager);
        
        log.info(&quot;线程&quot; + threadNum + &quot; 设置请求头:&quot;);
        log.info(&quot;  Authorization: &quot; + token.substring(0, 20) + &quot;...&quot;);
        log.info(&quot;  Refresh-Token: &quot; + refreshToken.substring(0, 20) + &quot;...&quot;);
    }
}</stringProp>
          </BeanShellPreProcessor>
