        <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="BeanShell 取样器" enabled="true">
          <stringProp name="BeanShellSampler.query">// 测试结束：将Map中的token写回CSV文件
import org.apache.commons.io.FileUtils;
import java.io.File;
import java.util.ArrayList;
import java.util.List;
import java.util.HashMap;
import java.text.SimpleDateFormat;
import java.util.Date;

log.info(&quot;===== 开始持久化Token =====&quot;);

try {
    // 1. 获取Map
    HashMap map = (HashMap) props.get(&quot;tokenMap&quot;);
    
    if (map == null) {
        log.error(&quot;tokenMap不存在&quot;);
        return;
    }
    
    // 2. 准备要写入的数据
    List lines = new ArrayList();
    lines.add(&quot;token,refreshToken&quot;); // 表头
    
    // 3. 按线程号排序
    List threadIds = new ArrayList();
    threadIds.addAll(map.keySet());
    
    // 冒泡排序（简单但够用）
    for (int i = 0; i &lt; threadIds.size() - 1; i++) {
        for (int j = 0; j &lt; threadIds.size() - i - 1; j++) {
            Integer a = (Integer) threadIds.get(j);
            Integer b = (Integer) threadIds.get(j + 1);
            if (a.intValue() &gt; b.intValue()) {
                threadIds.set(j, b);
                threadIds.set(j + 1, a);
            }
        }
    }
    
    // 4. 组装每一行数据
    for (int i = 0; i &lt; threadIds.size(); i++) {
        Integer threadId = (Integer) threadIds.get(i);
        String[] tokenPair = (String[]) map.get(threadId);
        lines.add(tokenPair[0] + &quot;,&quot; + tokenPair[1]);
    }
    
    // 5. 备份原文件
    String timeStr = new SimpleDateFormat(&quot;yyyyMMdd_HHmmss&quot;).format(new Date());
    File originalFile = new File(vars.get(&quot;filePath&quot;));
    
    if (originalFile.exists()) {
        File backupFile = new File(&quot;E:/hm-dianping/hm-dianping/backup/tokens_backup_&quot; + timeStr + &quot;.csv&quot;);
        backupFile.getParentFile().mkdirs();
        FileUtils.copyFile(originalFile, backupFile);
        log.info(&quot;已备份原文件到: &quot; + backupFile.getPath());
    }
    
    // 6. 写入新文件
    FileUtils.writeLines(originalFile, &quot;UTF-8&quot;, lines);
    //表头也包括进去了
    log.info(&quot;已写入 &quot; + lines.size() + &quot; 条token到CSV文件&quot;);
    
    // 7. 打印前3个看看
    for (int i = 0; i &lt; 3 &amp;&amp; i &lt; threadIds.size(); i++) {
        Integer id = (Integer) threadIds.get(i);
        String[] pair = (String[]) map.get(id);
        log.info(&quot;  线程&quot; + id + &quot;: &quot; + pair[0].substring(0, 20) + &quot;...&quot;);
    }
    
} catch (Exception e) {
    log.error(&quot;持久化失败: &quot; + e.toString());
}</stringProp>
        </BeanShellSampler>
