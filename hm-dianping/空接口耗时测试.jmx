          <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="BeanShell 后置处理程序">
            <boolProp name="resetInterpreter">false</boolProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="script">// 每个请求后：检查是否有新token，有则更新
int threadNum = ctx.getThreadNum();
int iteration = vars.getIteration();

// 获取响应码和响应头
String responseCode = prev.getResponseCode();
String headers = prev.getResponseHeaders();

// ===== 新增：检查请求是否成功 =====
boolean isSuccess = false;
try {
    int code = Integer.parseInt(responseCode);
    isSuccess = (code &gt;= 200 &amp;&amp; code &lt; 300); // 2xx 都算成功
} catch (Exception e) {
    log.error(&quot;解析响应码失败: &quot; + responseCode);
    isSuccess = false;
}

// 从响应头中查找新token
String newToken = null;

// 查找 Authorization: xxx
int authIndex = headers.indexOf(&quot;Authorization:&quot;);
if (authIndex &gt;= 0) {
    int start = authIndex + 13; // &quot;Authorization:&quot;的长度
    int end = headers.indexOf(&quot;\n&quot;, start);
    if (end &lt; 0) end = headers.length();
    newToken = headers.substring(start, end).trim();
}

// 查找 Refresh-Token: xxx
String newRefreshToken = null;
int refreshIndex = headers.indexOf(&quot;Refresh-Token:&quot;);
if (refreshIndex &gt;= 0) {
    int start = refreshIndex + 14; // &quot;Refresh-Token:&quot;的长度
    int end = headers.indexOf(&quot;\n&quot;, start);
    if (end &lt; 0) end = headers.length();
    newRefreshToken = headers.substring(start, end).trim();
}

// 获取旧的token值
String oldToken = vars.get(&quot;token&quot;);
String oldRefreshToken = vars.get(&quot;refreshToken&quot;);

// ===== 新增：请求失败的处理逻辑 =====
if (!isSuccess) {
    log.warn(&quot;线程&quot; + threadNum + &quot; 第&quot; + iteration + &quot;次迭代 请求失败，响应码: &quot; + responseCode);
    
    try {
        // 获取Map
        HashMap map = (HashMap) props.get(&quot;tokenMap&quot;);
        if (map != null) {
            Integer key = new Integer(threadNum);
            
            // 检查Map中当前是什么
            String[] currentPair = (String[]) map.get(key);
            
            // 如果Map中的token和当前使用的token不一样，说明被其他逻辑改过了？
            if (currentPair != null) {
                String currentToken = currentPair[0];
                String currentRefreshToken = currentPair[1];
                
                // 比较Map中的token和当前使用的token
                if (!currentToken.equals(oldToken)) {
                    log.warn(&quot;  警告: Map中的token和当前使用的token不一致&quot;);
                    log.warn(&quot;    Map中的token: &quot; + currentToken.substring(0, 20) + &quot;...&quot;);
                    log.warn(&quot;    当前使用的token: &quot; + oldToken.substring(0, 20) + &quot;...&quot;);
                }
            }
            
            // 重新把原来的token塞回Map（确保Map中的token是正确的）
            String[] restorePair = new String[2];
            restorePair[0] = oldToken;
            restorePair[1] = oldRefreshToken;
            map.put(key, restorePair);
            
            // 同时确保JMeter变量也是正确的
            vars.put(&quot;token&quot;, oldToken);
            vars.put(&quot;refreshToken&quot;, oldRefreshToken);
            
            log.info(&quot;  已恢复原有token: &quot; + oldToken.substring(0, 20) + &quot;...&quot;);
        }
    } catch (Exception e) {
        log.error(&quot;恢复token失败: &quot; + e.toString());
    }
    
    return; // 请求失败，直接返回，不继续处理token更新
}

// 如果找到新token
if (newToken != null || newRefreshToken != null) {
    // 确定最终要用的值
    String finalToken = newToken;
    if (finalToken == null) finalToken = oldToken;
    
    String finalRefreshToken = newRefreshToken;
    if (finalRefreshToken == null) finalRefreshToken = oldRefreshToken;
    
    // 1. 更新JMeter变量
    vars.put(&quot;token&quot;, finalToken);
    vars.put(&quot;refreshToken&quot;, finalRefreshToken);
    
    // 2. 更新Map中的token
    try {
        HashMap map = (HashMap) props.get(&quot;tokenMap&quot;);
        if (map != null) {
            Integer key = new Integer(threadNum);
            
            // 创建新的token对
            String[] newPair = new String[2];
            newPair[0] = finalToken;
            newPair[1] = finalRefreshToken;
            
            // 替换
            map.put(key, newPair);
            
            log.info(&quot;线程&quot; + threadNum + &quot; 第&quot; + iteration + &quot;次迭代 Token已更新&quot;);
            log.info(&quot;  旧Token: &quot; + oldToken.substring(0, 20) + &quot;...&quot;);
            log.info(&quot;  新Token: &quot; + finalToken.substring(0, 20) + &quot;...&quot;);
        }
    } catch (Exception e) {
        log.error(&quot;更新Map失败: &quot; + e.toString());
    }
} else {
    // 每10次迭代打印一次未更新日志
    if (iteration % 10 == 0) {
        log.info(&quot;线程&quot; + threadNum + &quot; 第&quot; + iteration + &quot;次迭代 无新token&quot;);
    }
}</stringProp>
          </BeanShellPostProcessor>
