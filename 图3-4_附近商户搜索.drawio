<!-- Redis 步骤 -->
<mxCell id="redis_step1" value="1. opsForGeo().search()&#10;Key: shop:geo:{typeId}&#10;半径: 5km" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9334E6;strokeWidth=1;fontSize=9;" vertex="1" parent="1"><mxGeometry x="430" y="240" width="160" height="46" as="geometry"/></mxCell>
