<!-- 有坐标分支 -->
<mxCell id="has_xy" value="有坐标&#10;Redis GEOSEARCH 按距离搜索" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FD;strokeColor=#9334E6;strokeWidth=2;fontSize=10;" vertex="1" parent="1"><mxGeometry x="420" y="180" width="180" height="40" as="geometry"/></mxCell>
